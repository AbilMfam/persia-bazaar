# ━━━ DigiMall API — Production (دیجی‌ای‌مال / diigiimall.ir) ━━━━━━━━━━━━━━━
#
# ⚠️ اگر این مخزن عمومی است، رمز واقعی را در نمونه commit نکنید؛ آن را با env روی سرور یا .env خارج از git قرار دهید و پسورد را در پنل مستقیم بچرخانید.

APP_NAME=DigiMall
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://diigiimall.ir

APP_FORCE_HTTPS=true
TRUST_ALL_PROXIES=true

LOG_CHANNEL=single
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=diigiima_mahdi
DB_USERNAME=diigiima_mahdi
DB_PASSWORD="@Mahdi1021"

BROADCAST_DRIVER=log
CACHE_STORE=file
CACHE_DRIVER=file
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# نام میزبان (نه URL کامل)، با رشتهٔ واردشده در APP_URL؛ www را اگر در DNS استفاده می‌کنید اضافه کنید.
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,diigiimall.ir,www.diigiimall.ir,https://localhost,capacitor://localhost

# مبدأ دقیق (Scheme + host + port)، جدا با کاما؛ دقیقاً باید با هدر Origin مرورگر/وب‌ویو یکی باشد.
CORS_ALLOWED_ORIGINS=https://diigiimall.ir,https://www.diigiimall.ir,https://localhost,capacitor://localhost

# اگر فقط Bearer token دارید می‌توانید false بگذارید تا preflight سبک‌تر شود؛ برای SPA کوکی دار true بماند منطقی است.
CORS_SUPPORTS_CREDENTIALS=true
