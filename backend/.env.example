APP_NAME=DigiMall
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# لوکال: همان پیش‌فرض؛ production: https://diigiimall.ir
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=digimall
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# در production آپدیت کن: diigiimall.ir برای وب‌اپ؛ منشاهای dev و capacitor را نگه دار.
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,localhost:5173,localhost:8080,localhost:8081,127.0.0.1,127.0.0.1:8000,diigiimall.ir,www.diigiimall.ir

SANCTUM_GUARD=web

# دامنهٔ وب production + اندروید (WebView پیش‌فرض https://localhost) — در سرور واقعی ست کنید.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080,http://127.0.0.1:8080,http://localhost:8081,http://127.0.0.1:8081,https://localhost,capacitor://localhost,https://diigiimall.ir,https://www.diigiimall.ir
