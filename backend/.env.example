APP_NAME=DigiMall
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

# لوکال: false؛ production/shared hosting با SSL پایدار: TRUST_ALL_PROXIES=true
TRUST_ALL_PROXIES=false
# لوکال: false؛ production با HTTPS: معمولا true تا URLها و تشخیص https درست باشد
APP_FORCE_HTTPS=false

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=digimall
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
# Laravel 11: CACHE_STORE trumps CACHE_DRIVER — set both برای سازگاری با اسکربت‌ها
CACHE_STORE=file
CACHE_DRIVER=file
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# تولید آمادهٔ production: `.env.production.example` یا راهنما `DEPLOYMENT_DIRECTADMIN.md`
# دامنه‌های SPA/cookie؛ اپ موبایل با Bearer token فقط باز هم نیاز ترکیب کردن capacitor دارد:
# در production شامل diigiimall.ir و در صورت نیاز www؛ شکل capacitor:// هم به host نرمال می‌شود — نمونه در backend/.env.production.example
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,localhost:8080,127.0.0.1,127.0.0.1:8000,https://localhost,capacitor://localhost

# مبداهای مرورگر/کپاسیتور مجاز — در production ست صریح (بدون *)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://localhost,capacitor://localhost
CORS_SUPPORTS_CREDENTIALS=true
