# Production API (embedded in builds that load this file via merge chain).
VITE_API_BASE_URL=https://diigiimall.ir/api

# اختیاری — فقط برای dev: بدون این، تا وقتی `VITE_API_BASE_URL` بالا ست است درخواست‌ها مستقیماً به API بالا می‌روند.
# برای پروکسی `/api` به Laravel محلی در dev، همین خط را ست کنید (مبدأ Laravel روی شبکهٔ شما، نه دامنهٔ زنده):
# VITE_DEV_API_PROXY_TARGET=http://<IP_یا_نام_میزبان>:8000
