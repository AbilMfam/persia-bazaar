# ━━━ توسعه (روزمره) ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# اگر `VITE_API_BASE_URL` اینجا ست نباشد، در مرورگر dev از مسیر `/api` و پروکسی Vite استفاده می‌شود.
# پیشنهاد: دو ترمینال — `npm run backend:dev` + `npm run dev`؛ یا یک‌خطی `npm run dev:full`.

# دستور شبکهٔ LAN برای تست موبایل روی مرورگر: npm run dev:full:lan
# بعد روی گوشی: http://<IP این رایانه>:5173/

# برای تست مستقیم به Laravel بدون پروکسی روی شبکهٔ محلی (اختیاری):
# VITE_API_BASE_URL=http://192.168.1.x:8000/api

# اگر Laravel پورت پیش‌فرض را عوض کردی و هنوز پروکسی dev می‌خواهی:
# VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:9000

# بدون پیشوند `/api`: فقط زمانی کاربرد دارد که `getApiBaseUrl()` مسیر `/api` برمی‌گرداند (dev در مرورگر):
# VITE_LARAVEL_ORIGIN=http://127.0.0.1:8000

# ━━━ production / بیلد اندروید ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# نمونهٔ آماده برای production: فایل .env.production.example را به .env.production کپی کنید یا معادلش را بگذارید.
