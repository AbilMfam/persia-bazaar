# ━━━ API (اپ اندروید / بیلد production) ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# همیشه همان پیش‌فرض مخزن (همچنین `.env.production`):
VITE_API_BASE_URL=https://diigiimall.ir/api

# ━━━ توسعه با Laravel محلی (اختیاری) ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# اگر می‌خواهید در `npm run dev` به‌جای دامنهٔ بالا از پروکسی Vite به Laravel بزنید،
# اول در `.env.local` خط بالا را کامنت/حذف کنید، سپس مبدأ Laravel را ست کنید:
# VITE_DEV_API_PROXY_TARGET=http://<YOUR_LAN_HOST>:8000

# SSR در dev بدون آدرس کامل API: برای resolve تصویر‌ها و هم‌خوان با مسیر `/api`:
# VITE_LARAVEL_ORIGIN=http://<YOUR_LAN_HOST>:8000

# دستور شبکهٔ LAN: npm run dev:full:lan — سپس روی گوشی آدرسی که ترمینال چاپ می‌کند را باز کنید.
