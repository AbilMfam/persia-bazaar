# ━━━ فرانت (Vite) — هنگام بیلد `npm run build` این مقادیر تزریق می‌شوند ━━━
VITE_API_BASE_URL=https://diigiimall.ir/api

# ━━━ Laravel API (روی سرور به `backend/.env` کپی کنید؛ رمزها را در مخزن قرار ندهید) ━━━
# الگوی کامل سرور: `backend/.env.production.example`

APP_NAME=DigiMall
APP_ENV=production
APP_DEBUG=false
APP_URL=https://diigiimall.ir

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=your_database
DB_USERNAME=your_user
DB_PASSWORD=your_secure_password

CACHE_DRIVER=file
CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=public
